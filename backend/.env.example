ADMIN_PASSWORD=admin123456

# AI translation can be configured in the administrator web page.
# Environment variables remain supported as a deployment alternative.
TRANSLATION_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
TRANSLATION_TIMEOUT_SECONDS=90
TRANSLATION_MAX_RETRIES=2

# OCR uses a local Tesseract installation when available in Windows PATH.

# Optional Windows OCR executable path. The installer fills this automatically.
TESSERACT_CMD=

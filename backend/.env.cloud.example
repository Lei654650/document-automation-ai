CLOUD_MODE=true
APP_DATA_DIR=/data
ADMIN_PASSWORD=CHANGE_TO_A_LONG_RANDOM_PASSWORD
PUBLIC_BASE_URL=https://your-domain.example
CORS_ORIGINS=https://your-domain.example
MAX_FILE_SIZE_MB=100

# AI translation (choose one provider)
TRANSLATION_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional Windows OCR executable path. The installer fills this automatically.
TESSERACT_CMD=

# Payment / Stripe
PAYMENT_TEST_MODE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=

# V24 PayPal Checkout (recommended for Vietnam merchant onboarding)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# Set to your public website URL in production
PUBLIC_BASE_URL=http://localhost:8000

# Paddle Billing (preferred third-party checkout)
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CHECKOUT_URL=
PADDLE_PRICE_MAP={}

# Authentication
AUTH_SECRET=replace-with-a-long-random-secret
SESSION_TTL_SECONDS=2592000
